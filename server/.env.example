DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require
JWT_SECRET=replace-with-at-least-32-random-characters
CLIENT_URL=http://localhost:5173
NODE_ENV=development

# Customer Google Sign-In (same OAuth web client ID as VITE_GOOGLE_CLIENT_ID)
GOOGLE_CLIENT_ID=

# Stripe test mode only for portfolio/demo deployments
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Transactional email (Brevo SMTP or compatible credentials)
SMTP_USER=
SMTP_PASS=
SENDER_EMAIL=

# Comma-separated bootstrap admin emails. Database role remains authoritative.
ADMIN_EMAILS=admin@example.com

# Product image uploads
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Background email workflows
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=
