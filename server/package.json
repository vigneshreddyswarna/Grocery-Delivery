{
  "name": "server",
  "version": "1.0.0",
  "description": "Express, Prisma, Stripe, and email services for the FreshCart grocery delivery platform.",
  "main": "index.js",
  "scripts": {
    "postinstall": "npx prisma generate",
    "start": "node dist/server.js",
    "dev": "tsx server.ts",
    "server": "nodemon --exec tsx server.ts",
    "build": "tsc",
    "seed": "tsx seed.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "type": "module",
  "overrides": {
    "@hono/node-server": "1.19.13"
  },
  "dependencies": {
    "@prisma/adapter-neon": "^7.9.0",
    "@prisma/client": "^7.9.0",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.10.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "inngest": "^4.13.0",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.2.0",
    "nodemailer": "^9.0.3",
    "stripe": "^22.3.2"
  },
  "devDependencies": {
    "@types/bcrypt": "^6.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/multer": "^2.2.0",
    "@types/node": "^26.1.1",
    "@types/nodemailer": "^8.0.1",
    "@types/supertest": "^7.2.1",
    "nodemon": "^3.1.14",
    "prisma": "^7.9.0",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
