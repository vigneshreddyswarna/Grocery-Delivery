{
    "compilerOptions": {
        "target": "ES2020",
        "module": "nodenext",
        "moduleResolution":"nodenext",
        "outDir": "./dist",
        "rootDir": "./",
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "server.ts",
        "seed.ts",
        "prisma.config.ts",
        "config/**/*.ts",
        "controllers/**/*.ts",
        "generated/**/*.ts",
        "inngest/**/*.ts",
        "middleware/**/*.ts",
        "routes/**/*.ts",
        "services/**/*.ts",
        "types/**/*.d.ts",
        "utils/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist",
        "tests"
    ]
}
